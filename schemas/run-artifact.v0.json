{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://evidenceweaver.dev/schemas/run-artifact.v0.json",
  "title": "EvidenceWeaver Run Artifact v0",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "task_id",
    "answer"
  ],
  "properties": {
    "schema_version": {
      "const": "run-artifact.v0"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "answer": {
      "type": "string",
      "minLength": 1
    },
    "final_citations": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["claim_id", "text"],
        "properties": {
          "claim_id": {"type": "string", "minLength": 1},
          "text": {"type": "string", "minLength": 1},
          "citations": {
            "type": "array",
            "items": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind"],
        "properties": {
          "kind": {"type": "string", "minLength": 1},
          "argument": {"type": "string"},
          "document_ids": {
            "type": "array",
            "items": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "evidence_graph": {
      "type": "object",
      "properties": {
        "graph_id": {"type": "string", "minLength": 1},
        "prompt_focus": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "source_nodes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["source_id", "title", "url", "opened"],
            "properties": {
              "source_id": {"type": "string", "minLength": 1},
              "title": {"type": "string", "minLength": 1},
              "url": {"type": "string", "minLength": 1},
              "source_type": {"type": "string"},
              "opened": {"type": "boolean"}
            }
          }
        },
        "claim_nodes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["claim_id", "text"],
            "properties": {
              "claim_id": {"type": "string", "minLength": 1},
              "text": {"type": "string", "minLength": 1},
              "citations": {
                "type": "array",
                "items": {"type": "string", "minLength": 1}
              },
              "focus_tokens": {
                "type": "array",
                "items": {"type": "string", "minLength": 1}
              },
              "status": {"type": "string"}
            }
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["edge_id", "kind", "from_id", "to_id"],
            "properties": {
              "edge_id": {"type": "string", "minLength": 1},
              "kind": {"type": "string", "minLength": 1},
              "from_id": {"type": "string", "minLength": 1},
              "to_id": {"type": "string", "minLength": 1}
            }
          }
        },
        "open_questions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["question_id", "text"],
            "properties": {
              "question_id": {"type": "string", "minLength": 1},
              "text": {"type": "string", "minLength": 1},
              "focus_tokens": {
                "type": "array",
                "items": {"type": "string", "minLength": 1}
              }
            }
          }
        }
      }
    },
    "diagnostics": {
      "type": "object",
      "properties": {
        "search_queries": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "iteration_count": {"type": "integer", "minimum": 0},
        "opened_source_ids": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "opened_source_count": {"type": "integer", "minimum": 0},
        "claim_count": {"type": "integer", "minimum": 0},
        "covered_prompt_focus_ratio": {"type": "number"},
        "uncovered_focus_tokens": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "notes": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "reward_bundle": {
      "type": "object",
      "properties": {
        "answer_score": {"type": "number"},
        "citation_score": {"type": "number"},
        "chain_score": {"type": "number"},
        "diversity_score": {"type": "number"},
        "efficiency_score": {"type": "number"},
        "total_score": {"type": "number"}
      }
    }
  }
}
